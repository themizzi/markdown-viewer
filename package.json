{
  "name": "markdown-viewer",
  "version": "1.0.0",
  "private": true,
  "author": "themizzi",
  "description": "Minimal Electron + TypeScript markdown viewer with Mermaid and file watching",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "start": "npm run build && electron out/main/main.js",
    "package": "npm run build && electron-builder --dir",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "cucumber-js --config e2e/cucumber.cjs",
    "test:e2e:headless": "HEADLESS=true cucumber-js --config e2e/cucumber.cjs",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": "eslint --max-warnings=0"
  },
  "build": {
    "appId": "com.markdownviewer.app",
    "productName": "markdown-viewer",
    "icon": "build/icon.png",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "build/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dir"
      ]
    },
    "linux": {
      "target": [
        "dir"
      ]
    }
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "github-markdown-css": "^5.8.1",
    "marked": "^15.0.0",
    "mermaid": "^11.6.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.2.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.0",
    "@vitest/coverage-istanbul": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@wdio/globals": "^9.26.1",
    "canvas": "^3.2.1",
    "electron": "41.0.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "memfs": "^4.56.11",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "wdio-electron-service": "^9.2.1",
    "webdriverio": "^9.26.1"
  }
}
